# Runtime mode
NODE_ENV=development
# API server port
PORT=3001
# MongoDB URI
MONGODB_URI=mongodb://mongo:27017/umurava_hr
# JWT secret (minimum 32 chars)
JWT_SECRET=your_super_secret_key_with_32_chars_minimum
# JWT TTL
JWT_EXPIRES_IN=24h
# Google Gemini API key
GEMINI_API_KEY=your_gemini_key
# Gemini model id
GEMINI_MODEL=gemini-1.5-pro
# Enable Redis-dependent features (queue/cache)
REDIS_ENABLED=false
# Redis connection
REDIS_URL=redis://redis:6379
# Max upload size in MB
MAX_FILE_SIZE_MB=10
# Allowed frontend URL for CORS
FRONTEND_URL=http://localhost:5173
# SMTP settings for instant email notifications + OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
# Set to false in local/dev when your network injects a self-signed cert
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
# OTP expiration time in minutes
OTP_EXPIRES_MINUTES=10
