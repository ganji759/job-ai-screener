# Runtime mode
NODE_ENV=development

# API server port
PORT=3001

# MongoDB URI
MONGODB_URI=mongodb://localhost:27017/job_ai_screener
# Optional: if Atlas `mongodb+srv` fails with querySrv ETIMEOUT, try public DNS (comma-separated)
# MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8

# JWT secret
JWT_SECRET=

# JWT TTL
JWT_EXPIRES_IN=24h

# Google Gemini API key
GEMINI_API_KEY= 

# Gemini model id (see https://ai.google.dev/gemini-api/docs/models )
GEMINI_MODEL=gemini-2.5-flash

# REST API version segment for @google/generative-ai (use v1 for current models)
GEMINI_API_VERSION=v1

# Default Gemini HTTP timeout (ms)
# GEMINI_TIMEOUT_MS=30000

# Umurava platform screening — keep total under ~60s (tune batch × timeout × retries)
# GEMINI_PLATFORM_BATCH_SIZE=10
# GEMINI_PLATFORM_TIMEOUT_MS=26000
# GEMINI_PLATFORM_RETRIES=1
# GEMINI_PLATFORM_WALL_MS=58000

# Pool insights follow-up call (after platform batches)
# GEMINI_INSIGHTS_TIMEOUT_MS=14000
# GEMINI_INSIGHTS_RETRIES=1

# Python AI service (backend/apps/ai). When set, Node forwards all Gemini calls here.
# When empty, Node uses the in-process @google/generative-ai SDK directly (fallback).
AI_SERVICE_URL=http://localhost:8000
# AI_SERVICE_TIMEOUT_BUFFER_MS=5000

# Enable Redis-dependent features (queue/cache)
REDIS_ENABLED=true

# Redis connection
REDIS_URL=

# Max upload size in MB
MAX_FILE_SIZE_MB=10

# Allowed frontend URL for CORS
FRONTEND_URL=http://localhost:3000
# Optional: extra allowed origins (comma-separated). Use for Vercel preview URLs or additional domains.
# CORS_ORIGINS=https://your-app.vercel.app,https://preview.your-app.vercel.app

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS_REJECT_UNAUTHORIZED=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM= @gmail.com

# OTP expiration time in minutes
OTP_EXPIRES_MINUTES=10

# NextAuth secret
NEXTAUTH_SECRET=

# API base URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:3001